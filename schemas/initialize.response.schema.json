{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/initialize.response.schema.json",
  "title": "Initialize Response",
  "description": "Lifecycle handshake response for entering the MGP ready state.",
  "allOf": [
    {
      "$ref": "response-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "data": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "chosen_version",
            "supported_versions",
            "lifecycle_phase",
            "session_mode",
            "transport_profile",
            "protocol_capabilities",
            "negotiated_capabilities",
            "negotiated_profiles",
            "server_info"
          ],
          "properties": {
            "chosen_version": {
              "type": "string",
              "pattern": "^v?[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
            },
            "supported_versions": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^v?[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              }
            },
            "minimum_supported_version": {
              "type": "string",
              "pattern": "^v?[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
            },
            "lifecycle_phase": {
              "type": "string",
              "enum": [
                "ready"
              ]
            },
            "session_mode": {
              "type": "string",
              "enum": [
                "stateless",
                "stateful"
              ]
            },
            "transport_profile": {
              "type": "string",
              "enum": [
                "stateless_http",
                "streamable_http"
              ]
            },
            "protocol_capabilities": {
              "$ref": "protocol-capabilities.schema.json"
            },
            "negotiated_capabilities": {
              "$ref": "negotiated-capabilities.schema.json"
            },
            "negotiated_profiles": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "core-memory",
                  "governance",
                  "interop",
                  "lifecycle"
                ]
              }
            },
            "server_info": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "version"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "version": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "discovery": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "capabilities_uri": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "deprecation_warnings": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "session_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  ]
}
