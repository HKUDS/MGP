{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/async-task.schema.json",
  "title": "MGP Async Task",
  "description": "Task handle for async MGP operations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "operation",
    "status",
    "request_id",
    "created_at",
    "updated_at",
    "progress",
    "total",
    "result",
    "error"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "type": "string",
      "enum": [
        "export",
        "import",
        "sync"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "progress": {
      "type": "number",
      "minimum": 0
    },
    "total": {
      "type": "number",
      "minimum": 0
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "code": {
          "$ref": "error-code.schema.json"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "code",
        "message"
      ]
    }
  }
}
