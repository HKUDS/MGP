{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/audit-query.response.schema.json",
  "title": "Audit Query Response",
  "allOf": [
    {
      "$ref": "response-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "data": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": ["events"],
          "properties": {
            "events": {
              "type": "array",
              "items": {
                "$ref": "audit-event.schema.json"
              }
            },
            "next_token": {
              "type": "string"
            }
          }
        }
      }
    }
  ]
}
