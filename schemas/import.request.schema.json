{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/import.request.schema.json",
  "title": "ImportMemories Request",
  "allOf": [
    {
      "$ref": "request-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "policy_context": {
          "allOf": [
            {
              "$ref": "policy-context.schema.json"
            },
            {
              "type": "object",
              "properties": {
                "requested_action": {
                  "const": "write"
                }
              }
            }
          ]
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "memories"
          ],
          "properties": {
            "memories": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "memory-object.schema.json"
              }
            },
            "merge_hint": {
              "$ref": "memory-merge-hint.schema.json"
            },
            "execution_mode": {
              "type": "string",
              "enum": [
                "sync",
                "async"
              ]
            },
            "timeout_ms": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  ]
}
