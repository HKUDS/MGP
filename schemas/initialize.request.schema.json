{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/initialize.request.schema.json",
  "title": "Initialize Request",
  "description": "Lifecycle handshake request for entering the MGP ready state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "client"
  ],
  "oneOf": [
    {
      "required": [
        "protocol_version"
      ]
    },
    {
      "required": [
        "supported_versions"
      ]
    }
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1,
      "description": "Client-generated identifier for the initialize request."
    },
    "protocol_version": {
      "type": "string",
      "pattern": "^v?[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$",
      "description": "Backward-compatible single-version shorthand for this handshake."
    },
    "supported_versions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "description": "MGP protocol versions supported by the client, ordered by client preference.",
      "items": {
        "type": "string",
        "pattern": "^v?[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
      }
    },
    "preferred_version": {
      "type": "string",
      "pattern": "^v?[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$",
      "description": "Explicit preferred version when using supported_versions negotiation."
    },
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "requested_capabilities": {
      "$ref": "protocol-capabilities.schema.json"
    },
    "runtime_capabilities": {
      "$ref": "runtime-capabilities.schema.json"
    },
    "requested_profiles": {
      "type": "array",
      "uniqueItems": true,
      "description": "Protocol profiles the client would like to enable for this interaction.",
      "items": {
        "type": "string",
        "enum": [
          "core-memory",
          "governance",
          "interop",
          "lifecycle"
        ]
      }
    },
    "transport_profile": {
      "type": "string",
      "description": "Preferred transport profile for the lifecycle handshake.",
      "enum": [
        "stateless_http",
        "streamable_http"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "preferred_version"
        ]
      },
      "then": {
        "required": [
          "supported_versions"
        ]
      }
    }
  ]
}
