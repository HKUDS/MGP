{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/import.response.schema.json",
  "title": "ImportMemories Response",
  "allOf": [
    {
      "$ref": "response-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "data": {
          "type": [
            "object",
            "null"
          ],
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "memory_ids",
                "written_count"
              ],
              "properties": {
                "memory_ids": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "written_count": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "task"
              ],
              "properties": {
                "task": {
                  "$ref": "async-task.schema.json"
                }
              }
            }
          ]
        }
      }
    }
  ]
}
