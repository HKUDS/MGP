{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/sync.request.schema.json",
  "title": "SyncMemories Request",
  "allOf": [
    {
      "$ref": "request-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "policy_context": {
          "allOf": [
            {
              "$ref": "policy-context.schema.json"
            },
            {
              "type": "object",
              "properties": {
                "requested_action": {
                  "const": "read"
                }
              }
            }
          ]
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "include_inactive": {
              "type": "boolean"
            },
            "cursor": {
              "type": "string",
              "minLength": 1
            },
            "pagination_token": {
              "type": "string",
              "minLength": 1
            },
            "execution_mode": {
              "type": "string",
              "enum": [
                "sync",
                "async"
              ]
            },
            "limit": {
              "type": "integer",
              "minimum": 1
            },
            "timeout_ms": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  ]
}
