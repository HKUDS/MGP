{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/expire-memory.response.schema.json",
  "title": "ExpireMemory Response",
  "allOf": [
    {
      "$ref": "response-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "data": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": ["memory_id", "state"],
          "properties": {
            "memory_id": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "const": "expired"
            }
          }
        }
      }
    }
  ]
}
