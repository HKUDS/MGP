{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/get-memory.response.schema.json",
  "title": "GetMemory Response",
  "allOf": [
    {
      "$ref": "response-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "data": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "memory",
            "return_mode",
            "redaction_info",
            "consumable_text"
          ],
          "properties": {
            "memory": {
              "$ref": "memory-object.schema.json"
            },
            "return_mode": {
              "$ref": "return-mode.schema.json"
            },
            "redaction_info": {
              "type": ["object", "null"],
              "allOf": [
                {
                  "if": { "type": "object" },
                  "then": { "$ref": "redaction-info.schema.json" }
                }
              ]
            },
            "consumable_text": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  ]
}
