{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/cancel-task.request.schema.json",
  "title": "Cancel Task Request",
  "description": "Request to cancel an async MGP task.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "task_id"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
