{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/memory-object.schema.json",
  "title": "MGP Memory Object",
  "description": "Canonical governed memory object for the Memory Governance Protocol.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "memory_id",
    "subject",
    "scope",
    "type",
    "content",
    "source",
    "created_at"
  ],
  "properties": {
    "memory_id": {
      "type": "string",
      "minLength": 1,
      "description": "Protocol-level identifier for the memory object."
    },
    "subject": {
      "$ref": "#/$defs/subject"
    },
    "scope": {
      "type": "string",
      "enum": [
        "user",
        "session",
        "task",
        "agent",
        "org",
        "shared_team"
      ],
      "description": "Visibility or applicability boundary for the memory."
    },
    "type": {
      "type": "string",
      "enum": [
        "profile",
        "preference",
        "episodic_event",
        "semantic_fact",
        "procedural_rule",
        "relationship",
        "checkpoint_pointer",
        "artifact_summary"
      ],
      "description": "Semantic type of the memory object."
    },
    "content": {
      "type": "object",
      "description": "Protocol-normalized payload for the memory object.",
      "additionalProperties": true
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score for the memory payload."
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ],
      "description": "Sensitivity label used by policy-aware consumers."
    },
    "retention_policy": {
      "type": "string",
      "minLength": 1,
      "description": "Retention policy identifier. Semantics are defined outside this schema."
    },
    "ttl_seconds": {
      "type": "integer",
      "minimum": 0,
      "description": "Requested time-to-live in seconds."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp for the memory object."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp for the memory object."
    },
    "assertion_mode": {
      "type": "string",
      "enum": [
        "asserted",
        "confirmed",
        "inferred",
        "derived",
        "imported",
        "observed"
      ],
      "description": "How the memory was asserted or derived."
    },
    "asserted_by": {
      "$ref": "#/$defs/subject"
    },
    "confirmed_by_user": {
      "type": "boolean",
      "description": "Whether the memory has been explicitly confirmed by the subject or user."
    },
    "evidence_refs": {
      "type": "array",
      "description": "Opaque references to evidence items supporting this memory.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence": {
      "type": "array",
      "description": "Structured evidence objects supporting this memory.",
      "items": {
        "$ref": "memory-evidence.schema.json"
      }
    },
    "derived_from": {
      "type": "array",
      "description": "Identifiers of source memories or evidence that this memory was derived from.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "valid_from": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Optional validity window start."
    },
    "valid_to": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Optional validity window end."
    },
    "backend_ref": {
      "type": "object",
      "description": "Opaque adapter-local handle or routing metadata. This field is not intended for portable vendor semantics and may be dropped when moving between implementations.",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "description": "Namespaced vendor or implementation extension fields that should preserve portable semantic meaning beyond one adapter.",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "preference"
          }
        }
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "memory-content-preference.schema.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "semantic_fact"
          }
        }
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "memory-content-semantic-fact.schema.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "relationship"
          }
        }
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "memory-content-relationship.schema.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "procedural_rule"
          }
        }
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "memory-content-procedural-rule.schema.json"
          }
        }
      }
    }
  ],
  "$defs": {
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "org",
            "task",
            "session",
            "custom"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "chat",
            "tool",
            "document",
            "human",
            "system",
            "external"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
