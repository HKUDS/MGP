{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/update-memory.request.schema.json",
  "title": "UpdateMemory Request",
  "allOf": [
    {
      "$ref": "request-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "policy_context": {
          "allOf": [
            {
              "$ref": "policy-context.schema.json"
            },
            {
              "type": "object",
              "properties": {
                "requested_action": {
                  "const": "update"
                }
              }
            }
          ]
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["memory_id", "patch"],
          "properties": {
            "memory_id": {
              "type": "string",
              "minLength": 1
            },
            "patch": {
              "type": "object",
              "additionalProperties": true
            },
            "updated_at": {
              "type": "string",
              "format": "date-time"
            },
            "timeout_ms": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  ]
}
