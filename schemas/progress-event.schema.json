{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/progress-event.schema.json",
  "title": "MGP Progress Event",
  "description": "Machine-readable progress payload for async task updates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "progress",
    "timestamp"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "progress": {
      "type": "number",
      "minimum": 0
    },
    "total": {
      "type": "number",
      "minimum": 0
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
