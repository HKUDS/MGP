{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/memory-content-relationship.schema.json",
  "title": "MGP Relationship Memory Content",
  "description": "Structured content shape for relationship memories.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "statement"
  ],
  "properties": {
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "keywords": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "subject_entity": {
      "type": "string",
      "minLength": 1
    },
    "relation": {
      "type": "string",
      "minLength": 1
    },
    "object_entity": {
      "type": "string",
      "minLength": 1
    },
    "valid_from": {
      "type": "string",
      "format": "date-time"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time"
    }
  }
}
