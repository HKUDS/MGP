{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mgp.dev/schemas/get-task.request.schema.json",
  "title": "Get Task Request",
  "description": "Request to retrieve the current state of an async MGP task.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "task_id"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
